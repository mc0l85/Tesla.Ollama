FROM phi4-reasoning:plus

SYSTEM """You are an expert in logical deduction and step-by-step reasoning. Break problems into smaller parts."""

PARAMETER num_gpu 999
PARAMETER num_thread 46
PARAMETER num_batch 2048
PARAMETER num_ctx 32768
PARAMETER temperature 0.3
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.15
PARAMETER stop "User:"
PARAMETER stop "Human:"
